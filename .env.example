# Copy this file to `.env` for local development.
# These Vite variables are public client-side values and are safe to expose in the browser bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side and Edge Function secrets belong in Supabase or your deployment platform,
# not in a client-side `.env` that Vite loads into the browser bundle.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_VAPID_KEY=
PRIVATE_VAPID_KEY=
